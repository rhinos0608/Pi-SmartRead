{
  "name": "pi-read-many",
  "version": "0.1.0",
  "description": "Batch file reads for Pi via read_multiple_files with adaptive packing under output limits",
  "author": "Gurpartap Singh",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gurpartap/pi-read-many.git"
  },
  "bugs": {
    "url": "https://github.com/Gurpartap/pi-read-many/issues"
  },
  "homepage": "https://github.com/Gurpartap/pi-read-many",
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "read_multiple_files",
    "read-many",
    "file-reading",
    "context-packing"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.ts",
    "read-many.ts",
    "config.ts",
    "chunking.ts",
    "embedding.ts",
    "intent-read.ts",
    "resolver.ts",
    "scoring.ts",
    "utils.ts",
    "repomap-tool.ts",
    "repomap.ts",
    "tags.ts",
    "cache.ts",
    "file-discovery.ts",
    "languages.ts",
    "pagerank.ts",
    "tree-context.ts",
    "hook.ts",
    "special.ts",
    "queries/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.2"
  },
  "dependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "pi": {
