{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "index.ts", "read-many.ts", "utils.ts", "config.ts",
    "scoring.ts", "chunking.ts", "embedding.ts", "resolver.ts",
    "intent-read.ts", "languages.ts", "cache.ts", "pagerank.ts",
    "tree-context.ts", "file-discovery.ts", "tags.ts", "repomap.ts",
    "repomap-tool.ts", "hook.ts", "special.ts", "test/**/*.ts"
  ]
}
